+    get() = startupProcedure.launchedUpdate?.id
+
+  override val embeddedUpdateId: UUID?
+    get() = getEmbeddedUpdate()?.id
+
+  companion object {
+    private val TAG = EnabledUpdatesController::class.java.simpleName
+  }
